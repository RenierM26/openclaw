FROM ghcr.io/openclaw/openclaw:latest

USER root

ENV DEBIAN_FRONTEND=noninteractive
ENV PIP_NO_CACHE_DIR=1
ENV ANDROID_PLATFORM_TOOLS=/opt/android/platform-tools
ENV WHISPER_VENV=/opt/whisper-venv
ENV PATH="${WHISPER_VENV}/bin:${ANDROID_PLATFORM_TOOLS}:${PATH}"

RUN set -eux; \
    echo 'deb http://deb.debian.org/debian trixie main contrib non-free-firmware' > /etc/apt/sources.list.d/trixie.list; \
    apt-get update && \
    apt-get install -y --no-install-recommends \
      docker.io \
      git \
      curl \
      wget \
      jq \
      ffmpeg \
      ripgrep \
      fd-find \
      fzf \
      rsync \
      zip \
      unzip \
      sqlite3 \
      netcat-openbsd \
      dnsutils \
      iputils-ping \
      traceroute \
      tcpdump \
      tshark \
      usbutils \
      build-essential \
      cmake \
      pkg-config \
      python3 \
      python3-pip \
      python3-venv \
      python3-dev \
      openssh-client \
      sshpass \
      expect \
      python-is-python3 \
      ca-certificates \
      procps \
      lsof \
      iproute2 \
      mtr-tiny \
      nmap \
      ethtool \
      xmlstarlet \
      nano \
    && apt-get install -y --no-install-recommends -t trixie \
    mesa-vulkan-drivers \
    vulkan-tools \
    libvulkan-dev \
    libgl1-mesa-dri \
    glslc \
    && ln -sf /usr/bin/fdfind /usr/local/bin/fd \
    && mkdir -p /opt/android \
    && wget -q https://dl.google.com/android/repository/platform-tools-latest-linux.zip -O /tmp/platform-tools.zip \
    && unzip -q /tmp/platform-tools.zip -d /opt/android \
    && ln -sf /opt/android/platform-tools/adb /usr/local/bin/adb \
    && ln -sf /opt/android/platform-tools/fastboot /usr/local/bin/fastboot \
    && npm install -g \
      @tobilu/qmd \
      mcporter \
      wacli \
    && chown -R node:node /usr/local/lib/node_modules/@tobilu/qmd \
    && pip3 install --break-system-packages \
      uv \
      frida-tools \
      requests \
      httpx \
      python-dotenv \
      msal \
      rich \
      tenacity \
      pyyaml \
    && python3 -m venv "${WHISPER_VENV}" \
    && "${WHISPER_VENV}/bin/pip" install --upgrade pip setuptools wheel \
    && "${WHISPER_VENV}/bin/pip" install openai-whisper \
    && ln -sf "${WHISPER_VENV}/bin/whisper" /usr/local/bin/whisper \
    && rm -rf /var/lib/apt/lists/* /tmp/platform-tools.zip

USER node
