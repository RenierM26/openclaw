FROM ghcr.io/openclaw/openclaw:latest

USER root

ENV DEBIAN_FRONTEND=noninteractive
ENV PIP_NO_CACHE_DIR=1
ENV ANDROID_PLATFORM_TOOLS=/opt/android/platform-tools
ENV WHISPER_VENV=/opt/whisper-venv

# Linuxbrew env
ENV HOMEBREW_PREFIX=/home/linuxbrew/.linuxbrew
ENV HOMEBREW_CELLAR=/home/linuxbrew/.linuxbrew/Cellar
ENV HOMEBREW_REPOSITORY=/home/linuxbrew/.linuxbrew/Homebrew
ENV HOMEBREW_NO_ANALYTICS=1
ENV HOMEBREW_NO_AUTO_UPDATE=1

ENV PATH="/home/node/.openclaw/npm/node_modules/.bin:/home/node/.openclaw/npm/.bin:${WHISPER_VENV}/bin:${ANDROID_PLATFORM_TOOLS}:/home/linuxbrew/.linuxbrew/bin:/home/linuxbrew/.linuxbrew/sbin:${PATH}"

# 1) APT sources
RUN set -eux; \
    apt-get update; \
    apt-get install -y --no-install-recommends ca-certificates curl gnupg; \
    mkdir -p -m 755 /etc/apt/keyrings; \
    echo 'deb http://deb.debian.org/debian trixie main contrib non-free-firmware' > /etc/apt/sources.list.d/trixie.list; \
    curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
      | gpg --dearmor -o /etc/apt/keyrings/githubcli.gpg; \
    chmod go+r /etc/apt/keyrings/githubcli.gpg; \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli.gpg] https://cli.github.com/packages stable main" \
      > /etc/apt/sources.list.d/github-cli.list; \
    curl -fsSL https://download.docker.com/linux/debian/gpg \
      | gpg --dearmor -o /etc/apt/keyrings/docker.gpg; \
    chmod go+r /etc/apt/keyrings/docker.gpg; \
    . /etc/os-release; \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/debian ${VERSION_CODENAME} stable" \
      > /etc/apt/sources.list.d/docker.list; \
    rm -rf /var/lib/apt/lists/*

# 2) Base OS packages + GitHub CLI + Docker CLI
RUN set -eux; \
    apt-get update; \
    apt-get install -y --no-install-recommends \
      docker-ce-cli \
      gh \
      git \
      curl \
      wget \
      jq \
      ffmpeg \
      ripgrep \
      tmux \
      golang-go \
      fd-find \
      fzf \
      rsync \
      zip \
      unzip \
      sqlite3 \
      netcat-openbsd \
      dnsutils \
      iputils-ping \
      traceroute \
      tcpdump \
      tshark \
      usbutils \
      build-essential \
      cmake \
      pkg-config \
      python3 \
      python3-pip \
      python3-venv \
      python3-dev \
      openssh-client \
      sshpass \
      expect \
      python-is-python3 \
      ca-certificates \
      procps \
      lsof \
      iproute2 \
      mtr-tiny \
      nmap \
      ethtool \
      xmlstarlet \
      nano \
      file \
      locales; \
    apt-get install -y --no-install-recommends -t trixie \
      mesa-vulkan-drivers \
      vulkan-tools \
      libvulkan-dev \
      libgl1-mesa-dri \
      glslc; \
    ln -sf /usr/bin/fdfind /usr/local/bin/fd; \
    rm -rf /var/lib/apt/lists/*

# 3) Android platform tools
RUN set -eux; \
    mkdir -p /opt/android; \
    wget -q https://dl.google.com/android/repository/platform-tools-latest-linux.zip -O /tmp/platform-tools.zip; \
    unzip -q /tmp/platform-tools.zip -d /opt/android; \
    ln -sf /opt/android/platform-tools/adb /usr/local/bin/adb; \
    ln -sf /opt/android/platform-tools/fastboot /usr/local/bin/fastboot; \
    rm -f /tmp/platform-tools.zip

# 4a) npm globals
RUN set -eux; \
    npm install -g \
      @tobilu/qmd \
      mcporter \
      clawhub \
      @steipete/oracle; \
    chown -R node:node /usr/local/lib/node_modules/@tobilu/qmd || true

# 4b) Go-based skill CLIs
RUN set -eux; \
    GOBIN=/usr/local/bin go install github.com/Hyaxia/blogwatcher/cmd/blogwatcher@latest; \
    GOBIN=/usr/local/bin go install github.com/steipete/gifgrep/cmd/gifgrep@latest; \
    GOBIN=/usr/local/bin go install github.com/steipete/sonoscli/cmd/sonos@latest; \
    GOBIN=/usr/local/bin go install github.com/steipete/blucli/cmd/blu@latest

# 5a) system Python helpers
RUN set -eux; \
    pip3 install --break-system-packages --ignore-installed \
      uv \
      frida-tools \
      requests \
      httpx \
      python-dotenv \
      msal \
      rich \
      tenacity \
      pyyaml \
      ruff \
      mypy \
      pyright \
      pytest \
      pytest-asyncio \
      pytest-cov \
      pytest-mock \
      coverage \
      tox \
      pre-commit \
      types-requests \
      types-PyYAML

# 5b) uv-based skill CLIs
RUN set -eux; \
 UV_TOOL_DIR=/opt/openclaw-tools/uv \
 UV_TOOL_BIN_DIR=/usr/local/bin \
 UV_LINK_MODE=copy \
 uv tool install nano-pdf

# 6) Whisper in isolated venv
RUN set -eux; \
    python3 -m venv "${WHISPER_VENV}"; \
    "${WHISPER_VENV}/bin/pip" install --upgrade pip setuptools wheel; \
    "${WHISPER_VENV}/bin/pip" install openai-whisper; \
    ln -sf "${WHISPER_VENV}/bin/whisper" /usr/local/bin/whisper

# 7) Playwright Chromium for OpenClaw browser automation
RUN set -eux; \
    mkdir -p /home/node/.cache/ms-playwright; \
    PLAYWRIGHT_BROWSERS_PATH=/home/node/.cache/ms-playwright \
      node /app/node_modules/playwright-core/cli.js install --with-deps chromium; \
    chromium_path="$(find /home/node/.cache/ms-playwright -path '*/chrome-linux64/chrome' -type f | head -n1)"; \
    test -n "$chromium_path"; \
    ln -sf "$chromium_path" /usr/local/bin/openclaw-chromium; \
    chown -R node:node /home/node/.cache/ms-playwright

# 8) Prepare Linuxbrew directory
RUN set -eux; \
    mkdir -p /home/linuxbrew/.linuxbrew; \
    mkdir -p /home/node/.cache/Homebrew; \
    chown -R node:node /home/linuxbrew /home/node/.cache

# 9) Install Linuxbrew as node user
USER node

RUN set -eux; \
    git clone --depth=1 https://github.com/Homebrew/brew /home/linuxbrew/.linuxbrew/Homebrew; \
    mkdir -p /home/linuxbrew/.linuxbrew/bin; \
    ln -sf ../Homebrew/bin/brew /home/linuxbrew/.linuxbrew/bin/brew; \
    brew --version; \
    brew analytics off

# Optional: install brew packages here, still as node


USER root

# 10) Smoke checks
RUN set -eux; \
    docker --version; \
    gh --version; \
    qmd --version; \
    mcporter --version; \
    whisper --help >/dev/null; \
    adb version; \
    openclaw-chromium --version; \
    tmux -V; \
    clawhub --version || clawhub --help >/dev/null; \
    oracle --version || oracle --help >/dev/null; \
    blogwatcher --help >/dev/null; \
    gifgrep --help >/dev/null; \
    sonos --help >/dev/null; \
    nano-pdf version; \
    blu --help >/dev/null; \
    brew --version

USER node
