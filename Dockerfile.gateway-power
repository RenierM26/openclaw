FROM ghcr.io/openclaw/openclaw:latest

USER root

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      docker.io \
      git \
      curl \
      jq \
      ffmpeg \
      ripgrep \
      build-essential \
      python3 \
      python3-pip \
      python3-venv \
      python3-dev \
    && rm -rf /var/lib/apt/lists/*

ENV PIP_NO_CACHE_DIR=1

USER node